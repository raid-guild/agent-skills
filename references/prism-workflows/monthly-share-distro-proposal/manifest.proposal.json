{
  "key": "monthly-share-distro-proposal",
  "name": "Participation Cycle Share Distro Proposal",
  "version": 6,
  "description": "Collect Participation Steward cycle evidence, build share distro artifacts, prepare a DAO proposal draft, route through human review, and submit onchain only after approval.",
  "entrypoint": "collect-activity",
  "workflowPath": "workflow.md",
  "target": {
    "required": false
  },
  "agentConfig": {
    "runtime": "codex-runtime",
    "mode": "main-agent",
    "identity": "prism-workflow-agent",
    "skills": [
      "prism-api-reader",
      "moloch-dao-ops",
      "cookiejar-activity-reader"
    ],
    "delegation": {
      "allowed": false,
      "maxAgents": 1
    }
  },
  "steps": [
    {
      "key": "collect-activity",
      "label": "Collect Cycle Activity",
      "type": "agent",
      "instructionPath": "steps/collect-activity.md",
      "next": "build-share-distro"
    },
    {
      "key": "build-share-distro",
      "label": "Build Cycle Distro",
      "type": "agent",
      "instructionPath": "steps/build-share-distro.md",
      "next": "build-proposal-payload"
    },
    {
      "key": "build-proposal-payload",
      "label": "Build Proposal Payload",
      "type": "agent",
      "instructionPath": "steps/build-proposal-payload.md",
      "next": "draft-discord"
    },
    {
      "key": "draft-discord",
      "label": "Draft Discord Review",
      "type": "agent",
      "instructionPath": "steps/draft-discord.md",
      "next": "review"
    },
    {
      "key": "review",
      "label": "Review",
      "type": "gate",
      "instructionPath": "steps/review.md",
      "routes": {
        "approved": "submit-onchain",
        "changesRequested": "build-share-distro",
        "rejected": "closed"
      }
    },
    {
      "key": "submit-onchain",
      "label": "Submit Onchain",
      "type": "agent",
      "instructionPath": "steps/submit-onchain.md",
      "next": "closed"
    },
    {
      "key": "closed",
      "label": "Closed",
      "type": "terminal"
    }
  ]
}
